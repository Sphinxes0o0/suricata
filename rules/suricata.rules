# 拦截 ICMP ping 报文的规则
alert icmp any any -> any any (msg:"ICMP Ping Request Detected"; icode:0; itype:8; classtype:attempted-recon; sid:1000001; rev:1;)
alert icmp any any -> any any (msg:"ICMP Ping Reply Detected"; icode:0; itype:0; classtype:not-suspicious; sid:1000002; rev:1;)
drop icmp any any -> any any (msg:"\n ->> DROP any ICMP in MacOS testing \n"; sid:1000003;)
alert tcp any any -> any any (msg:"TCP SYN Packet Detected"; tcp.flags:S; sid:1000004; rev:1;)
alert tcp any any -> any any (msg:"TCP ACK Packet Detected"; tcp.flags:A; sid:1000005; rev:1;)
alert tcp any any -> any any (msg:"TCP FIN Packet Detected"; tcp.flags:F; sid:1000006; rev:1;)

alert tcp any any -> any any (msg:"TCP SYN Flood Attack Detected"; tcp.flags:S; threshold: type threshold, track by_src, count 1000, seconds 10; sid:1000007; rev:1;)

alert tcp any any -> any any (msg:"TCP FIN Flood Attack Detected"; tcp.flags:F; threshold: type threshold, track by_src, count 1000, seconds 10; sid:1000008; rev:1;)

alert tcp any any -> any any (msg:"TCP RST Flood Attack Detected"; tcp.flags:R; threshold: type threshold, track by_src, count 1000, seconds 10; sid:1000009; rev:1;)

alert tcp any any -> any any (msg:"TCP SYN Flood Attack - High Rate"; tcp.flags:S; detection_filter: track by_src, count 120, seconds 1; sid:1000010; rev:1;)

alert tcp any any -> any any (msg:"TCP FIN Flood Attack - High Rate"; tcp.flags:F; detection_filter: track by_src, count 120, seconds 1; sid:1000011; rev:1;)

alert tcp any any -> any any (msg:"TCP RST Flood Attack - High Rate"; tcp.flags:R; detection_filter: track by_src, count 120, seconds 1; sid:1000012; rev:1;)
