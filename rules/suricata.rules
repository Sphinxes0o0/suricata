# 拦截 ICMP ping 报文的规则
#alert icmp any any -> any any (msg:"ICMP Ping Request Detected"; icode:0; itype:8; classtype:attempted-recon; sid:1000001; rev:1;)
#alert icmp any any -> any any (msg:"ICMP Ping Reply Detected"; icode:0; itype:0; classtype:not-suspicious; sid:1000002; rev:1;)
drop icmp any any -> any any (msg:"\n ->> DROP any ICMP in MacOS testing \n"; sid:1000003;)